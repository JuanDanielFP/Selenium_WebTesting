{
  "name": "selenium-webtesting",
  "version": "1.0.0",
  "description": "Selenium Webdriver testing using Mocha with Mochawesome reports",
  "scripts": {
    "jalanin": "mocha test --recursive --timeout 60000",
    "jalanin-mochawesome": "mocha test --recursive --timeout 60000 --reporter mochawesome",
    "jalanin-simple-html": "mocha test --recursive --timeout 60000 --reporter mocha-simple-html-reporter --reporter-options output=report.html",
    "jalanin-sesi-10-hook": "mocha test test/test-sauce.js --recursive --timeout 60000"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "selenium-webdriver": "^4.15.0"
  },
  "devDependencies": {
    "mocha": "^10.8.2",
    "mocha-simple-html-reporter": "^2.0.0",
    "mochawesome": "^7.1.3"
  }
}
